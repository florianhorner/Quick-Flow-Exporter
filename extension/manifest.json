{
  "manifest_version": 3,
  "name": "Quick Flow Exporter",
  "version": "1.0.0",
  "description": "Extract Quick Flows content with one click for the Quick Flow Exporter tool.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background/background.js"
  }
}
