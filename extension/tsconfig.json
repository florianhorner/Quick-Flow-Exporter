  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["chrome-types"],
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["popup", "content", "background"]
}
